<%@ page language="java" contentType="text/html; charset=UTF-8"
    pageEncoding="UTF-8"%>
<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>Railway Portal</title>

<link rel="stylesheet" href="style.css">

<link rel="preconnect" href="https://fonts.googleapis.com">
<link href="https://fonts.googleapis.com/css2?family=Poppins:wght@300;400;500;600;700&display=swap" rel="stylesheet">

<link rel="stylesheet"
href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.5.2/css/all.min.css">

<style>
*{
margin:0;
padding:0;
box-sizing:border-box;
font-family:'Poppins',sans-serif;
}

body{
background:#f4f7fb;
}

/* Header */

header{
display:flex;
justify-content:space-between;
align-items:center;
padding:18px 8%;
background:#003366;
position:fixed;
width:100%;
top:0;
z-index:999;
}

.logo{
font-size:28px;
font-weight:700;
color:#fff;
}

.logo i{
margin-right:8px;
color:#ff9800;
}

nav ul{
display:flex;
list-style:none;
}

nav ul li{
margin-left:30px;
}

nav ul li a{
text-decoration:none;
color:#fff;
font-size:17px;
transition:.3s;
}

nav ul li a:hover{
color:#ff9800;
}

.login-btn{
background:#ff9800;
padding:10px 20px;
border-radius:30px;
}

.login-btn:hover{
background:#fff;
color:#003366;
}

/* Hero */

.hero{
height:100vh;
background:url("Feature-Image-Top-ten-rail-operators-in-2020.avif") center/cover;
display:flex;
justify-content:center;
align-items:center;
margin-top:75px;
}

.overlay{
background:rgba(0,0,0,.55);
padding:60px;
border-radius:15px;
text-align:center;
color:white;
}

.overlay h1{
font-size:60px;
margin-bottom:20px;
}

.overlay p{
font-size:22px;
margin-bottom:35px;
}

.overlay a{
text-decoration:none;
background:#ff9800;
padding:15px 40px;
border-radius:40px;
color:white;
font-size:18px;
transition:.3s;
}

.overlay a:hover{
background:#003366;
}

/* Services */

.services{
padding:80px 8%;
background:white;
text-align:center;
}

.services h2{
font-size:40px;
color:#003366;
margin-bottom:50px;
}

.service-box{
display:grid;
grid-template-columns:repeat(auto-fit,minmax(250px,1fr));
gap:30px;
}

.card{
background:white;
padding:40px;
border-radius:12px;
box-shadow:0 5px 20px rgba(0,0,0,.15);
transition:.4s;
}

.card:hover{
transform:translateY(-10px);
}

.card i{
font-size:55px;
color:#ff9800;
margin-bottom:20px;
}

.card h3{
margin-bottom:15px;
color:#003366;
}

/* Announcement */

.announcement{
padding:80px;
background:#003366;
color:white;
text-align:center;
}

.announcement h2{
font-size:38px;
margin-bottom:35px;
}

.news{
max-width:700px;
margin:auto;
text-align:left;
}

.news p{
font-size:20px;
padding:15px;
border-bottom:1px solid rgba(255,255,255,.2);
}

/* Statistics */

.stats{
display:grid;
grid-template-columns:repeat(auto-fit,minmax(220px,1fr));
gap:25px;
padding:80px;
background:#f8f9fb;
}

.box{
background:white;
padding:40px;
text-align:center;
border-radius:10px;
box-shadow:0 5px 15px rgba(0,0,0,.1);
}

.box h2{
font-size:45px;
color:#003366;
}

.box p{
margin-top:15px;
font-size:18px;
}

/* Footer */

footer{
background:#001f3f;
color:white;
text-align:center;
padding:50px 20px;
}

.footer-content h2{
font-size:35px;
margin-bottom:15px;
}

.footer-content p{
margin-bottom:20px;
}

.social i{
font-size:25px;
margin:10px;
cursor:pointer;
transition:.3s;
}

.social i:hover{
color:#ff9800;
}

.copy{
margin-top:30px;
font-size:15px;
opacity:.8;
}

/* Responsive */

@media(max-width:768px){

header{
flex-direction:column;
padding:20px;
}

nav ul{
flex-direction:column;
margin-top:20px;
}

nav ul li{
margin:12px 0;
}

.overlay{
padding:35px;
}

.overlay h1{
font-size:36px;
}

.overlay p{
font-size:18px;
}

}
</style>

</head>
<body>

<header>

<div class="logo">
<i class="fa-solid fa-train"></i>
<span>RailConnect</span>
</div>

<nav>

<ul>

<li><a href=>Home</a></li>

<li><a href="#">About</a></li>

<li><a href="index.jsp">Services</a></li>

<li><a href="index2.jsp">Booking</a></li>

<li><a href="#">Contact</a></li>

<li><a href="loginpage.jsp" class="login-btn">Login</a></li>

</ul>

</nav>

</header>


<section class="hero">

<div class="overlay">

<h1>Welcome to Railway Portal</h1>

<p>Experience Fast, Secure & Digital Railway Services.</p>

<a href="#">Explore Services</a>

</div>

</section>


<section class="services">

<h2>Our Services</h2>

<div class="service-box">

<div class="card">

<i class="fa-solid fa-train-subway"></i>

<h3>Train Information</h3>

<p>View complete train details and schedules.</p>

</div>

<div class="card">

<i class="fa-solid fa-map-location-dot"></i>

<h3>Station Guide</h3>

<p>Explore stations and available facilities.</p>

</div>

<div class="card">

<i class="fa-solid fa-utensils"></i>

<h3>Food Services</h3>

<p>Find food services available at stations.</p>

</div>

<div class="card">

<i class="fa-solid fa-headset"></i>

<h3>24x7 Support</h3>

<p>Customer support available anytime.</p>

</div>

</div>

</section>


<section class="announcement">

<h2>Latest Announcements</h2>

<div class="news">

<p>✔ Summer Special Trains Available</p>

<p>✔ New Railway Safety Guidelines</p>

<p>✔ Platform Information Updated</p>

<p>✔ New Railway Tourism Packages</p>

</div>

</section>


<section class="stats">

<div class="box">

<h2>13,000+</h2>

<p>Daily Trains</p>

</div>

<div class="box">

<h2>7,000+</h2>

<p>Railway Stations</p>

</div>

<div class="box">

<h2>20M+</h2>

<p>Passengers</p>

</div>

<div class="box">

<h2>24x7</h2>

<p>Customer Support</p>

</div>

</section>


<footer>

<div class="footer-content">

<h2>RailConnect</h2>

<p>Fast • Safe • Reliable Railway Information Portal</p>

<div class="social">

<i class="fab fa-facebook"></i>

<i class="fab fa-instagram"></i>

<i class="fab fa-twitter"></i>

<i class="fab fa-linkedin"></i>

</div>

</div>

<p class="copy">
© 2026 RailConnect. All Rights Reserved.
</p>

</footer>

</body>
</html>
